# Copy this file to .env and set values for your environment
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=ddd_inventory
DB_USERNAME=ddd_user
DB_PASSWORD=secret

APP_ENV=local
APP_DEBUG=true

# Shopify integration — required for stock sync and webhook handling
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxx
# Found in Shopify Admin → Settings → Notifications → Webhooks → Signing secret
SHOPIFY_WEBHOOK_SECRET=your-webhook-signing-secret
